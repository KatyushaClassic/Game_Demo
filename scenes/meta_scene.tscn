[gd_scene load_steps=4 format=3 uid="uid://metascene"]

[ext_resource type="Script" path="res://scripts/ui/scene_nav.gd" id="1_nav"]
[ext_resource type="Script" path="res://scripts/systems/meta_progression.gd" id="2_meta"]
[ext_resource type="Script" path="res://scripts/systems/synthesis_system.gd" id="3_syn"]

[node name="MetaScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_nav")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Label" type="Label" parent="Center/VBox"]
layout_mode = 2
text = "局外成长场景（成长/合成系统已挂载）"

[node name="Back" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "返回主菜单"

[node name="MetaSystem" type="Node" parent="."]
script = ExtResource("2_meta")

[node name="SynthesisSystem" type="Node" parent="."]
script = ExtResource("3_syn")

[connection signal="pressed" from="Center/VBox/Back" to="." method="_on_back_pressed"]
