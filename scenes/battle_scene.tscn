[gd_scene load_steps=5 format=3 uid="uid://battlescene"]

[ext_resource type="Script" path="res://scripts/ui/scene_nav.gd" id="1_nav"]
[ext_resource type="Script" path="res://scripts/systems/ship_builder.gd" id="2_ship"]
[ext_resource type="Script" path="res://scripts/systems/weapon_group_manager.gd" id="3_weapon"]
[ext_resource type="Script" path="res://scripts/systems/special_module_manager.gd" id="4_special"]

[node name="BattleScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_nav")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Label" type="Label" parent="Center/VBox"]
layout_mode = 2
text = "战斗场景（船体/武器/特殊系统已挂载）"

[node name="Back" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "返回主菜单"

[node name="ShipBuilderSystem" type="Node" parent="."]
script = ExtResource("2_ship")

[node name="WeaponSystem" type="Node" parent="."]
script = ExtResource("3_weapon")

[node name="SpecialSystem" type="Node" parent="."]
script = ExtResource("4_special")

[connection signal="pressed" from="Center/VBox/Back" to="." method="_on_back_pressed"]
