[gd_scene load_steps=2 format=3 uid="uid://mainmenu"]

[ext_resource type="Script" path="res://scripts/ui/main_menu.gd" id="1_menu"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_menu")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Center/VBox"]
layout_mode = 2
text = "Ship Tower Roguelike - Main UI"
horizontal_alignment = 1

[node name="OpenSystems" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "进入系统组装场景"

[node name="OpenMap" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "进入地图场景"

[node name="OpenBattle" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "进入战斗场景"

[node name="OpenMeta" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "进入局外成长场景"

[connection signal="pressed" from="Center/VBox/OpenSystems" to="." method="_on_open_systems_pressed"]
[connection signal="pressed" from="Center/VBox/OpenMap" to="." method="_on_open_map_pressed"]
[connection signal="pressed" from="Center/VBox/OpenBattle" to="." method="_on_open_battle_pressed"]
[connection signal="pressed" from="Center/VBox/OpenMeta" to="." method="_on_open_meta_pressed"]
