[gd_scene load_steps=3 format=3 uid="uid://mapscene"]

[ext_resource type="Script" path="res://scripts/ui/scene_nav.gd" id="1_nav"]
[ext_resource type="Script" path="res://scripts/systems/map_generator.gd" id="2_map"]

[node name="MapScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_nav")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Label" type="Label" parent="Center/VBox"]
layout_mode = 2
text = "地图场景（MapGenerator 已挂载）"

[node name="Back" type="Button" parent="Center/VBox"]
layout_mode = 2
text = "返回主菜单"

[node name="MapSystem" type="Node" parent="."]
script = ExtResource("2_map")

[connection signal="pressed" from="Center/VBox/Back" to="." method="_on_back_pressed"]
